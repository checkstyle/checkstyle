                }
              },
              "shortDescription": {
                "text": "IllegalToken"
              },
              "fullDescription": {
                "text": "<div>\n Checks for illegal tokens. By default, labels are prohibited.\n <\/div>\n\n <p>\n Rationale: Certain language features can harm readability, lead to\n confusion or are not obvious to novice developers. Other features\n may be discouraged in certain frameworks, such as not having\n native methods in Enterprise JavaBeans components.\n <\/p>"
              }
            }
