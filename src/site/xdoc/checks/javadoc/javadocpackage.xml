            </tr>
            <tr>
              <td><a id="allowLegacy"/><a href="#allowLegacy">allowLegacy</a></td>
              <td>Allow legacy <code>package.html</code> file to be used.</td>
              <td><a href="../../property_types.html#boolean">boolean</a></td>
