<?xml version="1.0" encoding="UTF-8"?>
<document xmlns="http://maven.apache.org/XDOC/2.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/XDOC/2.0 https://maven.apache.org/xsd/xdoc-2.0.xsd">
  <head>
    <title>SayHello</title>
  </head>
  <body>
    <section name="SayHello">
      <p>Since Checkstyle 1.0.0</p>
      <subsection name="Description" id="SayHello_Description">
        <p>
          Say hello.
        </p>
        <p>
          Parent is <code>com.puppycrawl.tools.checkstyle.TreeWalker</code>
        </p>
        <p>
          Violation Message Keys:
        </p>
        <ul>
        <li>
          <code>say.hello</code>
        </li>
        </ul>
      </subsection>

      <subsection name="Examples" id="SayHello_Examples">
        <p id="Example1-config">
          To configure the check:
        </p>
        <div class="wrapper"><pre class="prettyprint"><code class="language-xml">
&lt;module name="Checker"&gt;
  &lt;module name="TreeWalker"&gt;
    &lt;module name="SayHello"/&gt;
  &lt;/module&gt;
&lt;/module&gt;
</code></pre></div>
        <p id="Example1-code">Example:</p>
        <div class="wrapper"><pre class="prettyprint"><code class="language-java">
public class Example1 { // violation, 'Say Hello'
    public void sayHello() {
    }
}

class ExampleAnother { // ok, has hello variable
    String hello = "hello";
}

class ExampleWithOtherVariable { // violation, variable exists but isn't 'hello'
    String world = "world";
}
</code></pre></div>
      </subsection>

      <subsection name="Example of Usage" id="SayHello_Example_of_Usage">
        <ul>
          <li>
            <a href="https://github.com/search?q=path%3Aconfig%20path%3A**%2Fcheckstyle-checks.xml+repo%3Acheckstyle%2Fcheckstyle+SayHello">
            Checkstyle Style</a>
          </li>
        </ul>
      </subsection>

      <subsection name="Violation Messages" id="SayHello_Violation_Messages">
        <ul>
          <li>
            <a href="https://github.com/search?q=path%3Asrc%2Fmain%2Fresources%2Fcom%2Fpuppycrawl%2Ftools%2Fcheckstyle%2Fchecks%2Fcoding+path%3A**%2Fmessages*.properties+repo%3Acheckstyle%2Fcheckstyle+%22say.hello%22">
              say.hello
            </a>
          </li>
        </ul>
        <p>
          All messages can be customized if the default message doesn't suit you.
          Please <a href="../../config.html#Custom_messages">see the documentation</a>
          to learn how to.
        </p>
      </subsection>

      <subsection name="Package" id="SayHello_Package">
        <p>
          com.puppycrawl.tools.checkstyle.checks.coding
        </p>
      </subsection>

      <subsection name="Parent Module" id="SayHello_Parent_Module">
        <p>
          <a href="../../config.html#TreeWalker">TreeWalker</a>
        </p>
      </subsection>
    </section>
  </body>
