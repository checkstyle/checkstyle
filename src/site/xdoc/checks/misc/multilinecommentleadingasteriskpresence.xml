  <head>
    <title>MultilineCommentLeadingAsteriskPresence</title>
  </head>
  <body>
    <section name="MultilineCommentLeadingAsteriskPresence">
      <p>Since Checkstyle 13.9.0</p>
      <subsection name="Description" id="MultilineCommentLeadingAsteriskPresence_Description">
        <div>
          Checks if the
          <a href="https://www.oracle.com/java/technologies/javase/codeconventions-comments.html">
          multi-line comments</a> have leading asterisks on each line.
        </div>

        <p>
          Every line in multi-line comment should have leading asterisk including blank line.
        </p>
      </subsection>

      <subsection name="Examples" id="MultilineCommentLeadingAsteriskPresence_Examples">
        <p id="Example1-config">To configure the check:</p>
        <div class="wrapper"><pre class="prettyprint"><code class="language-xml">
&lt;module name="Checker"&gt;
  &lt;module name="TreeWalker"&gt;
    &lt;module name="MultilineCommentLeadingAsteriskPresence"/&gt;
  &lt;/module&gt;
&lt;/module&gt;
</code></pre></div>

        <p id="Example1-code">Example:</p>
        <div class="wrapper"><pre class="prettyprint"><code class="language-java">
public class Example1 {

  /*
   * Line has leading asterisk.
   */
  void foo() {}

  // violation 2 lines below 'Multiline comment should start with leading asterisk'
  /* Line with leading asterisk
     Line with leading asterisk
  */
  void bar() {}

  /* Single line comment */
  void method() {}

}
</code></pre></div>
      </subsection>

