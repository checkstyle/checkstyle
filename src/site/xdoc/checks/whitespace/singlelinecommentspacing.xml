  <head>
    <title>SingleLineCommentSpacing</title>
  </head>
  <body>
    <section name="SingleLineCommentSpacing">
      <p>Since Checkstyle 12.2</p>
      <subsection name="Description" id="SingleLineCommentSpacing_Description">
        <div>
          Checks spacing around single-line comments.
        </div>
      </subsection>

      <subsection name="Examples" id="SingleLineCommentSpacing_Examples">
        <p id="Example1-config">
          To configure the check:
        </p>
        <div class="wrapper"><pre class="prettyprint"><code class="language-xml">
&lt;module name="Checker"&gt;
  &lt;module name="TreeWalker"&gt;
    &lt;module name="SingleLineCommentSpacing"/&gt;
  &lt;/module&gt;
&lt;/module&gt;
</code></pre></div>
        <p id="Example1-code">Example:</p>
        <div class="wrapper"><pre class="prettyprint"><code class="language-java">
class Example1 {
  void method() {
    int ok = 1; // ok

    int both = 1;//bad // 2 violations
    int afterOnly = 2; //bad // violation 'should be followed by whitespace before comment text.'
    int beforeOnly = 3;// bad // violation 'should be preceded by whitespace when trailing code.'
    int bareComment = 4;//

    //comment-only line // violation 'should be followed by whitespace before comment text.'
    ///
    //////
    // comment-only line with proper spacing
  }
}
</code></pre></div>
      </subsection>

