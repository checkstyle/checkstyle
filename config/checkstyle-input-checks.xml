<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <property name="haltOnException" value="false"/>

  <property name="cacheFile" value="target/cache_input_resources"/>

  <!-- Suppressions for resources -->
  <module name="SuppressionFilter">
    <property name="file"
             value="config/checkstyle-input-suppressions.xml"/>
  </module>

  <module name="RegexpSingleline">
    <property name="id" value="noCheckstyleInInputs"/>
    <property name="format" value="import com.puppycrawl.tools.checkstyle"/>
    <property name="fileExtensions" value="java"/>
    <property name="message" value="Inputs should not reference checkstyle's own files"/>
  </module>

  <module name="RegexpMultiline">
    <property name="id" value="violationBetweenAnnotationAndMethod"/>
    <property name="format"
              value="\n[ \t]*@\w+[^\n]*\n[ \t]*//[ \t]*violation"/>
    <property name="fileExtensions" value="java"/>
    <message key="regexp.exceeded"
             value="Violation comment must not be placed between an annotation and its target.
Place it before the annotation block instead."/>
  </module>

  <module name="RegexpMultiline">
    <property name="id" value="violationBetweenJavadocAndMethod"/>
    <property name="format"
              value="\n[ \t]+\*/[ \t]*\n[ \t]*//[ \t]*violation"/>
    <property name="fileExtensions" value="java"/>
    <message key="regexp.exceeded"
             value="Violation comment must not be placed between a Javadoc block and its target.
Place it before the Javadoc block instead."/>
  </module>

  <module name="TreeWalker">
    <module name="Regexp">
      <property name="id" value="UnnecessaryOkComment"/>
      <property name="format"
               value="(?i)\/\/\s*ok$"/>
      <property name="illegalPattern" value="true"/>
      <message key="illegal.regexp"
               value="'// ok' comments should have an explanation, or they are unnecessary."/>
    </module>
  </module>
</module>
